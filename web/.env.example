# Serveur d'inférence (équipe INFRA)
# Ollama: http://localhost:11434 | Triton: http://localhost:8000
OLLAMA_URL=http://localhost:11434

# Nom du modèle servi par le backend d'inférence
MODEL_NAME=phi3.5-financial

# Paramètres d'inférence par défaut
TEMPERATURE=0.7
MAX_TOKENS=512

# Timeout des requêtes vers le serveur (secondes)
REQUEST_TIMEOUT=120
